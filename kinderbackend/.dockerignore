# ── Python bytecode & caches ─────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
.ruff_cache/
.mypy_cache/
.pytest_cache/

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Secrets / local config — NEVER bake into an image ────────────────────────
.env
.env.*
!.env.example

# ── Local SQLite databases ────────────────────────────────────────────────────
*.db
*.db-shm
*.db-wal

# ── Tests & coverage (not needed at runtime) ──────────────────────────────────
test_*.py
conftest.py
pytest.ini
coverage.xml
htmlcov/

# ── Dev-only dependencies & tooling ──────────────────────────────────────────
requirements-dev.txt
pyproject.toml

# ── Version control ───────────────────────────────────────────────────────────
.git/
.gitignore
.gitattributes

# ── Documentation ─────────────────────────────────────────────────────────────
*.md
*.rst

# ── Windows convenience scripts ───────────────────────────────────────────────
*.bat
*.cmd

# ── IDE / OS metadata ─────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
