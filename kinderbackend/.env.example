# Example placeholders only. Replace every CHANGE_ME value locally.
# Requires: pip install "psycopg[binary]"
DATABASE_URL=postgresql+psycopg://CHANGE_ME_USER:CHANGE_ME_PASSWORD@CHANGE_ME_HOST:5432/CHANGE_ME_DB
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE_SECONDS=1800

# JWT / auth placeholders
KINDER_JWT_SECRET=CHANGE_ME
SECRET_KEY=CHANGE_ME
JWT_SECRET_KEY=CHANGE_ME

# Admin seed is for local/dev use only. Keep disabled unless you explicitly need it.
ENABLE_ADMIN_SEED_ENDPOINT=false
ADMIN_SEED_SECRET=CHANGE_ME
ADMIN_SEED_PASSWORD=CHANGE_ME
ADMIN_SEED_EMAIL=change-me@example.invalid
ADMIN_SEED_NAME=CHANGE_ME

# Local fallback: leave DATABASE_URL unset to use sqlite:///kinder.db
